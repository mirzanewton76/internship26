  padding: 1px 4px;
  height: calc(var(--jp-private-document-search-button-height) + 2px);
  flex-shrink: 0;
}

.jp-DocumentSearch-replace-button-wrapper:focus {
  outline-width: var(--jp-focus-outline-width);
  outline-color: var(--jp-focus-outline-color);
  outline-style: solid;
