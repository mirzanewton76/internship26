.jp-SideBar.lm-TabBar[data-orientation='horizontal'] {
  min-height: calc(
    var(--jp-private-sidebar-tab-horizontal-height) +
      var(--jp-private-sidebar-tab-horizontal-scrollbar-height) +
      var(--jp-border-width)
  );
  max-height: calc(
