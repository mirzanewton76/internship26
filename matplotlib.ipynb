.lm-ScrollBar[data-orientation='horizontal'] .lm-ScrollBar-thumb {
  height: 100%;
  min-width: 15px;
  border-left: 1px solid var(--jp-border-color1);
  border-right: 1px solid var(--jp-border-color1);
