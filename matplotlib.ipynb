  border-bottom: 1px solid var(--jp-border-color2);
}

.jp-arrayFieldWrapper .field-description {
  padding: 4px 0;
  white-space: pre-wrap;
}

.jp-arrayFieldWrapper .array-item {
  width: 100%;
  border: 1px solid var(--jp-border-color2);
  border-radius: 4px;
  margin: 4px;
  position: relative;
}

.jp-ArrayOperations {
  display: flex;
  margin-left: 8px;
}

.field-array-of-object .jp-ArrayOperations {
  position: absolute;
  right: 2px;
  top: 10px;
}

/* Display the array operations toolbar on hover only for array of objects */
.jp-arrayFieldWrapper
  .field-array-of-object
  .array-item:not(:hover):not(:focus-within)
  .jp-ArrayOperations {
  display: none;
