.jp-DirListing-itemModified {
  text-align: right;
}

.jp-DirListing-itemFileSize {
  text-align: right;
}

.jp-DirListing-itemCreated {
  text-align: right;
}

.jp-DirListing-editor {
  flex: 1 0 64px;
